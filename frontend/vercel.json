{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && cd ../backend && npm install && npm run prisma:generate",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
