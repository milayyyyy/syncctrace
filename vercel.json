{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "public": false,
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "framework": "vite",
      "routePrefix": "/"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/api",
      "framework": "express",
      "buildCommand": "npm run prisma:generate && npm run build",
      "entrypoint": "src/index.ts"
    }
  }
}
