# Backend environment — copy to .env and fill in values
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"   # Supabase Dashboard → Settings → API → JWT Settings
PORT=4000
FRONTEND_URL="http://localhost:5174"
OPENROUTER_API_KEY="sk-or-v1-..."                  # openrouter.ai → API Keys → Create Key (free)
